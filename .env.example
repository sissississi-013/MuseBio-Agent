# Muse Bio AI Agent Environment Variables
# Copy this file to .env and fill in your values

# Required: Your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Optional: Override the default model (default: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# Optional: API server settings (only for musebio_api.py)
# API_HOST=0.0.0.0
# API_PORT=8000
